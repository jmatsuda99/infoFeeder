#!/usr/bin/env python

from pathlib import Path
import subprocess
import sys


def main():
    repo_root = Path(__file__).resolve().parent.parent
    python_exe = repo_root / ".venv" / "Scripts" / "python.exe"
    commit_message_file = Path(sys.argv[1]).resolve()

    if python_exe.exists():
        subprocess.run([str(python_exe), str(repo_root / "bump_version.py"), str(commit_message_file)], check=True)
    else:
        subprocess.run(["python", str(repo_root / "bump_version.py"), str(commit_message_file)], check=True)

    subprocess.run(["git", "-C", str(repo_root), "add", "VERSION"], check=True)


if __name__ == "__main__":
    main()
